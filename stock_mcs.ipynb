        "    plt.plot(\n",
        "        simulation_results[stock_to_plot][:, i],\n",
        "        alpha=0.2\n",
        "    )\n",
        "\n",
        "plt.title(f\"Sample Monte Carlo Simulations - {stock_to_plot}\")\n",
        "plt.xlabel(\"Trading Days\")\n",
